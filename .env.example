GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash   # optional, this is the default

# Required for TikTok connection: free signing key from https://www.eulerstream.com
# The backend will still boot without this, but TikTok connections will fail.
EULER_API_KEY=your_euler_stream_api_key

# Ports
HTTP_PORT=3000
WS_PORT=8080

# CORS — set to your deployed dashboard's URL once you have one, e.g.
# ALLOWED_ORIGINS=https://your-dashboard.vercel.app
# Comma-separate multiple origins. "*" allows any origin (fine for early local testing only).
ALLOWED_ORIGINS=*

# NOTE: Product info, AI personality/instructions, and bid rules are no longer
# set here — they're managed live through the REST API (see README) so your
# dashboard can edit them without restarting the backend.
